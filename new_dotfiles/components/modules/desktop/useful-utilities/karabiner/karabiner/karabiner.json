{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "f20 to cmd+space or ctrl+option",
                        "manipulators": [
                            {
                                "from": { "key_code": "f20" },
                                "to": [
                                    {
                                        "key_code": "left_control",
                                        "modifiers": ["left_option"]
                                    }
                                ],
                                "to_if_alone": [
                                    {
                                        "key_code": "spacebar",
                                        "modifiers": ["left_command"]
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "from": { "key_code": "f20", "modifiers": { "optional": ["any"] } },
                                "to": [
                                    {
                                        "key_code": "left_control",
                                        "modifiers": ["left_option"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "cmd-L to lock screen",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "l",
                                    "modifiers": { "mandatory": ["control", "option"] }
                                },
                                "to": [
                                    {
                                        "key_code": "q",
                                        "modifiers": ["control", "command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "cmd-left/right to prev/next track",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "left_arrow",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "to": [{ "consumer_key_code": "scan_previous_track" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "right_arrow",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "to": [{ "consumer_key_code": "scan_next_track" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "ctrl+v to cmd+space + cmd+4 (clipboard history)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "v",
                                    "modifiers": { "mandatory": ["control", "option"] }
                                },
                                "parameters": { "basic.to_delayed_action_delay_milliseconds": 250 },
                                "to": [
                                    {
                                        "key_code": "spacebar",
                                        "modifiers": ["command"]
                                    }
                                ],
                                "to_delayed_action": {
                                    "to_if_canceled": [],
                                    "to_if_invoked": [
                                        {
                                            "key_code": "4",
                                            "modifiers": ["command"]
                                        }
                                    ]
                                },
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Change left_option to left_ctrl except in WezTerm",
                        "enabled": false,
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.github\\.wez\\.wezterm"
                                        ],
                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "from": { "key_code": "left_option" },
                                "to": [{ "key_code": "left_control" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Change left_cmd to left_option except in WezTerm",
                        "enabled": false,
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.github\\.wez\\.wezterm"
                                        ],
                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "from": { "key_code": "left_command" },
                                "to": [{ "key_code": "left_option" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Change left_ctrl to left_cmd except in WezTerm",
                        "enabled": false,
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.github\\.wez\\.wezterm"
                                        ],
                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "from": { "key_code": "left_control" },
                                "to": [{ "key_code": "left_command" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "cmd+tab to ctrl+tab",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "tab",
                                    "modifiers": {
                                        "mandatory": ["command"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "tab",
                                        "modifiers": ["control"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "devices": [
                {
                    "identifiers": { "is_keyboard": true },
                    "simple_modifications": [
                        {
                            "from": { "apple_vendor_top_case_key_code": "keyboard_fn" },
                            "to": [{ "key_code": "left_command" }]
                        },
                        {
                            "from": { "key_code": "left_control" },
                            "to": [{ "apple_vendor_top_case_key_code": "keyboard_fn" }]
                        }
                    ]
                }
            ],
            "name": "Default profile",
            "selected": true,
            "simple_modifications": [
                {
                    "from": { "key_code": "caps_lock" },
                    "to": [{ "key_code": "left_control" }]
                },
                {
                    "from": { "key_code": "left_command" },
                    "to": [{ "key_code": "left_option" }]
                },
                {
                    "from": { "key_code": "left_control" },
                    "to": [{ "key_code": "left_command" }]
                },
                {
                    "from": { "key_code": "left_option" },
                    "to": [{ "key_code": "f20" }]
                },
                {
                    "from": { "key_code": "right_command" },
                    "to": [{ "key_code": "right_option" }]
                },
                {
                    "from": { "key_code": "right_option" },
                    "to": [{ "key_code": "right_command" }]
                }
            ],
            "virtual_hid_keyboard": { "keyboard_type_v2": "iso" }
        }
    ]
}